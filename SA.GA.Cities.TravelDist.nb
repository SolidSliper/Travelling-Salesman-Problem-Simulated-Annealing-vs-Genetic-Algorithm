 Background->RGBColor[
  1, 0.9, 0.8],ExpressionUUID->"eead3ff5-4769-410c-97fd-f44711750e3d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"P", "[", 
    RowBox[{"df_", ",", "T_"}], "]"}], ":=", 
   RowBox[{"Min", "[", 
    RowBox[{"1", ",", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "df"}], "/", "T"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"P", "[", 
      RowBox[{"df", ",", "T"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"df", ",", 
       RowBox[{"-", "200"}], ",", "500"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
       RowBox[{"0", ",", "1.05"}], "}"}]}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<df [km]\>\"", ",", "\"\<P\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLabel", "->", 
      RowBox[{"Row", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<T = \>\"", ",", "T"}], "}"}], "]"}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"T", ",", "50"}], "}"}], ",", "1", ",", "500"}], "}"}]}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.9869854467001495`*^9, 3.9869854495836315`*^9}, {
  3.987048610192713*^9, 3.9870486123575077`*^9}},
 CellLabel->"In[26]:=",ExpressionUUID->"d533ddda-fee0-8c42-b9b6-ee8d84ed90c6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Find T0 empirically", "Subsection",
 CellChangeTimes->{{3.6641921713318*^9, 3.6641921840348*^9}, {
  3.6641929906428003`*^9, 3.6641929958227997`*^9}, {3.6641931161438*^9, 
  3.6641931187728*^9}, {3.665921974243*^9, 3.66592197983*^9}, {
  3.671178302872568*^9, 3.671178306998539*^9}, {3.671178449172576*^9, 
  3.671178473937583*^9}, {3.6713517167178583`*^9, 3.6713517335727277`*^9}},
 Background->RGBColor[
  1, 0.9, 0.8],ExpressionUUID->"18b04d25-bda0-4f05-b223-cb51ee335f3e"],

Cell["\<\
Set T0 so that approximately 1/2 of longer paths are accepted\
\>", "Text",
 CellChangeTimes->{{3.6713581216145782`*^9, 
  3.6713581741488543`*^9}},ExpressionUUID->"27e5fe6e-1692-4873-8a46-\
4852344d8197"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"random", " ", 
     RowBox[{"walk", ":", 
      RowBox[{"zbiera", " ", "kladne", " ", "df", " ", "hodnoty"}]}]}], ",", 
    RowBox[{
     RowBox[{"riesi", " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"-", 
        RowBox[{"<", 
         RowBox[{"df", "+"}], ">", 
         RowBox[{"/", "T0"}]}]}], "]"}]}], "=", "0.5"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"findT0", "[", 
      RowBox[{"x0_", ",", "neighbour_", ",", 
       RowBox[{"samples_", ":", "1000"}]}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"x", "=", "x0"}], ",", "xnew", ",", "df", ",", 
         RowBox[{"dfList", "=", 
          RowBox[{"{", "}"}]}]}], "}"}], ",", 
       RowBox[{
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"xnew", "=", 
            RowBox[{"neighbour", "[", "x", "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"df", "=", 
            RowBox[{
             RowBox[{"f", "[", "xnew", "]"}], "-", 
             RowBox[{"f", "[", "x", "]"}]}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"df", ">", "0"}], ",", 
             RowBox[{"AppendTo", "[", 
              RowBox[{"dfList", ",", "df"}], "]"}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"x", "=", "xnew"}]}], ",", 
          RowBox[{"{", "samples", "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"Mean", "[", "dfList", "]"}]}], "/", 
         RowBox[{"Log", "[", "0.5", "]"}]}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"T0auto", "=", 
     RowBox[{"findT0", "[", 
      RowBox[{"x0", ",", "neighbourC"}], "]"}]}], ";"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<T0 = \>\"", ",", "T0auto", ",", "\"\< km\>\""}], 
    "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9869854562818375`*^9, 3.9869854791248245`*^9}},
 CellLabel->"In[28]:=",ExpressionUUID->"714ca659-2bff-cc41-be76-67d75e5d838e"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"T0 = \"\>", "\[InvisibleSpace]", "579.822374689087`", 
   "\[InvisibleSpace]", "\<\" km\"\>"}],
  SequenceForm["T0 = ", 579.822374689087, " km"],
  Editable->False]], "Print",
 CellChangeTimes->{3.9870620299783783`*^9, 3.9875876738318176`*^9, 
  3.9876480985517635`*^9, 3.9876723260268154`*^9},
 CellLabel->
