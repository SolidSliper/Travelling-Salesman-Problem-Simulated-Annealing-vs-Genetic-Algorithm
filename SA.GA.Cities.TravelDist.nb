Cell[BoxData[{
 RowBox[{"AbsoluteTiming", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"unit", "=", 
    RowBox[{"Switch", "[", 
     RowBox[{"quantity", ",", "\"\<TravelDistance\>\"", ",", 
      TemplateBox[{"1", "\"km\"", "kilometer", "\"Kilometers\""},
       "Quantity"], ",", "\"\<TravelTime\>\"", ",", 
      TemplateBox[{"1", "\"min\"", "minute", "\"Minutes\""},
       "Quantity"]}], "]"}]}], ";", "\[IndentingNewLine]", 
   RowBox[{"L", "=", 
    RowBox[{"ParallelTable", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", "n", "}"}], ",", 
      RowBox[{"{", "n", "}"}]}], "]"}]}], ";", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"distance", " ", "matrix"}], ",", " ", 
     RowBox[{"dimensionless", " ", "-", " ", 
      RowBox[{"faster", " ", "computations"}]}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"i", "=", "1"}], ",", 
     RowBox[{"i", "\[LessEqual]", "n"}], ",", 
     RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"L", "\[LeftDoubleBracket]", 
        RowBox[{"i", ",", "i"}], "\[RightDoubleBracket]"}], "=", "0"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"j", "=", 
         RowBox[{"i", "+", "1"}]}], ",", 
        RowBox[{"j", "\[LessEqual]", "n"}], ",", 
        RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"L", "\[LeftDoubleBracket]", 
           RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}], "=", 
          RowBox[{
           RowBox[{
            RowBox[{"TD", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{
               "r", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}], ",", 
               RowBox[{
               "r", "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}]}], 
              "}"}], "]"}], "[", "quantity", "]"}], "/", "unit"}]}], ";", 
         RowBox[{"(*", 
          RowBox[{"travel", " ", "distance", " ", "between", " ", "cities", " ", 
           RowBox[{
           "r", "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}], " ", 
           "and", " ", 
           RowBox[{
           "r", "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}], " ", 
           "in", " ", "kilometers"}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"L", "\[LeftDoubleBracket]", 
           RowBox[{"j", ",", "i"}], "\[RightDoubleBracket]"}], "=", 
          RowBox[{"L", "\[LeftDoubleBracket]", 
           RowBox[{"i", ",", "j"}], "\[RightDoubleBracket]"}]}], ";"}]}], 
       "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", "]"}]}], 
  "\[IndentingNewLine]", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"L", "//", "MatrixForm"}], "*)"}]}]}], "Input",
