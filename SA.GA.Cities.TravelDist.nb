Cell[CellGroupData[{

Cell["Algorithm", "Subsection",
 CellChangeTimes->{{3.6641921713318*^9, 3.6641921840348*^9}, {
  3.6641929906428003`*^9, 3.6641929958227997`*^9}, {3.6641931161438*^9, 
  3.6641931187728*^9}, {3.665921974243*^9, 3.66592197983*^9}, {
  3.671178302872568*^9, 3.671178306998539*^9}, {3.671178449172576*^9, 
  3.671178473937583*^9}},
 Background->RGBColor[
  1, 0.9, 0.8],ExpressionUUID->"8373f762-3372-4170-8e8c-3fe69e229c78"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"X", "=", 
    RowBox[{"{", "x0", "}"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"alpha", "=", "0.99"}], ";"}], "   "}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Tmin", "=", "0.00001"}], ";"}], "  "}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"kmax", "=", "50"}], ";"}], "     "}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"T", "=", "T0auto"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"While", "[", 
    RowBox[{
     RowBox[{"T", ">", "Tmin"}], ",", 
     RowBox[{
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"xnew", "=", 
          RowBox[{"neighbourC", "[", 
           RowBox[{"Last", "[", "X", "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"df", "=", 
          RowBox[{
           RowBox[{"f", "[", "xnew", "]"}], "-", 
           RowBox[{"f", "[", 
            RowBox[{"Last", "[", "X", "]"}], "]"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"P", "[", 
             RowBox[{"df", ",", "T"}], "]"}], ">=", 
            RowBox[{"RandomReal", "[", "]"}]}], ",", 
           RowBox[{"AppendTo", "[", 
            RowBox[{"X", ",", "xnew"}], "]"}]}], "]"}]}], ",", 
        RowBox[{"{", "kmax", "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"T", "=", 
       RowBox[{"alpha", "*", "T"}]}], ";"}]}], "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Steps stored : \>\"", ",", 
    RowBox[{"Length", "[", "X", "]"}]}], "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<Initial f    : \>\"", ",", 
    RowBox[{"f", "[", "x0", "]"}], ",", "\"\< km\>\""}], "]"}], ";"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Final   f    : \>\"", ",", 
   RowBox[{"f", "[", 
    RowBox[{"Last", "[", "X", "]"}], "]"}], ",", "\"\< km\>\""}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.986985488009268*^9, 3.986985499058201*^9}, {
   3.987588080578884*^9, 3.987588107119179*^9}, 3.987588519971773*^9, 
