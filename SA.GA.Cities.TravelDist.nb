Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"neighbourA", "[", "x_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"xn", "=", "x"}], ",", "i"}], "}"}], ",", 
     RowBox[{
      RowBox[{"i", "=", 
       RowBox[{"RandomInteger", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", 
          RowBox[{
           RowBox[{"Length", "[", "x", "]"}], "-", "1"}]}], "}"}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"xn", "[", 
          RowBox[{"[", "i", "]"}], "]"}], ",", 
         RowBox[{"xn", "[", 
          RowBox[{"[", 
           RowBox[{"i", "+", "1"}], "]"}], "]"}]}], "}"}], "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"xn", "[", 
          RowBox[{"[", 
           RowBox[{"i", "+", "1"}], "]"}], "]"}], ",", 
         RowBox[{"xn", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", "xn"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9869853674533653`*^9, 3.9869853828590565`*^9}},
 CellLabel->"In[23]:=",ExpressionUUID->"b5f26e2f-98aa-a44b-89d2-dcafeeda54a3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["2) Exchange of two random points", "Subsubsection",
 CellChangeTimes->{{3.6641921713318*^9, 3.6641921840348*^9}, {
   3.6641929906428003`*^9, 3.6641929958227997`*^9}, {3.6641931161438*^9, 
   3.6641931187728*^9}, {3.664263382932*^9, 3.6642633887679996`*^9}, {
