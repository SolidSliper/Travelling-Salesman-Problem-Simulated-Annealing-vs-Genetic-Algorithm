   3.668425076106518*^9}, {3.670845506998*^9, 3.670845510764*^9}, {
   3.671178330983548*^9, 3.671178331398546*^9}, {3.671178756026657*^9, 
   3.671178784561699*^9}, {3.671183753610241*^9, 3.671183761509226*^9}, {
   3.671184277627537*^9, 3.6711843062765455`*^9}, {3.671184525939602*^9, 
   3.671184526385603*^9}, {3.6711848345513477`*^9, 3.6711848369333487`*^9}, 
   3.6711893026909957`*^9},
 Background->RGBColor[
  1, 1, 0.85],ExpressionUUID->"6df3e794-8865-4c8d-ba21-3704032c4f45"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"neighbourC", "[", "x_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"xn", "=", "x"}], ",", "i", ",", "j"}], "}"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"i", ",", "j"}], "}"}], "=", 
       RowBox[{"Sort", "[", 
        RowBox[{"RandomSample", "[", 
         RowBox[{
          RowBox[{"Range", "[", 
           RowBox[{"Length", "[", "x", "]"}], "]"}], ",", "2"}], "]"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"xn", "[", 
        RowBox[{"[", 
         RowBox[{"i", ";;", "j"}], "]"}], "]"}], "=", 
       RowBox[{"Reverse", "[", 
        RowBox[{"xn", "[", 
         RowBox[{"[", 
          RowBox[{"i", ";;", "j"}], "]"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "xn"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[25]:=",ExpressionUUID->"1b67b234-7485-9b49-95ed-d809ca68d679"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Probability function", "Subsection",
 CellChangeTimes->{{3.6641921713318*^9, 3.6641921840348*^9}, {
  3.6641929906428003`*^9, 3.6641929958227997`*^9}, {3.6641931161438*^9, 
