            RowBox[{"\"\<Color\>\"", "->", "Black"}], ",", 
            RowBox[{"\"\<Scale\>\"", "->", "0.07"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}]}], "}"}], ",", 
      RowBox[{"GeoRange", "->", 
       RowBox[{"Entity", "[", 
        RowBox[{"\"\<Country\>\"", ",", "\"\<Ukraine\>\""}], "]"}]}], ",", 
      RowBox[{"ImageSize", "->", "1000"}]}], "]"}], ",", 
