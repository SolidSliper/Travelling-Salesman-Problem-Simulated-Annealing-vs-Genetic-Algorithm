Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"orderCrossover", "[", 
    RowBox[{"p1_", ",", "p2_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"m", "=", 
        RowBox[{"Length", "[", "p1", "]"}]}], ",", "i", ",", "j", ",", "seg", 
       ",", "rest"}], "}"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"i", ",", "j"}], "}"}], "=", 
       RowBox[{"Sort", "[", 
        RowBox[{"RandomSample", "[", 
         RowBox[{
          RowBox[{"Range", "[", "m", "]"}], ",", "2"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"seg", "=", 
       RowBox[{"p1", "[", 
        RowBox[{"[", 
         RowBox[{"i", ";;", "j"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"rest", "=", 
       RowBox[{"Select", "[", 
        RowBox[{"p2", ",", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"MemberQ", "[", 
            RowBox[{"seg", ",", "#"}], "]"}]}], "&"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"rest", "[", 
         RowBox[{"[", 
          RowBox[{"1", ";;", 
           RowBox[{"i", "-", "1"}]}], "]"}], "]"}], ",", "seg", ",", 
        RowBox[{"rest", "[", 
         RowBox[{"[", 
          RowBox[{"i", ";;"}], "]"}], "]"}]}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"tournamentSelect", "[", 
    RowBox[{"population_", ",", "fvals_", ",", 
     RowBox[{"tournSize_", ":", "3"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "idx", "}"}], ",", 
     RowBox[{
      RowBox[{"idx", "=", 
       RowBox[{"RandomSample", "[", 
        RowBox[{
         RowBox[{"Range", "[", 
          RowBox[{"Length", "[", "population", "]"}], "]"}], ",", 
         "tournSize"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"population", "[", 
       RowBox[{"[", 
        RowBox[{"idx", "[", 
         RowBox[{"[", 
          RowBox[{"First", "[", 
           RowBox[{"Ordering", "[", 
            RowBox[{
             RowBox[{"fvals", "[", 
              RowBox[{"[", "idx", "]"}], "]"}], ",", "1"}], "]"}], "]"}], 
          "]"}], "]"}], "]"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"geneticAlgorithm", "[", 
    RowBox[{
    "popSize_", ",", "nElite_", ",", "ngen_", ",", "Pm_", ",", "neighbour_", ",", 
     RowBox[{"tournSize_", ":", "4"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "pop", ",", "fvals", ",", "eliteIdx", ",", "newPop", ",", "p1", ",", 
       "p2", ",", "child", ",", "bestIdx", ",", "history"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"pop", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"RandomSample", "[", 
          RowBox[{"Range", "[", "n", "]"}], "]"}], ",", 
         RowBox[{"{", "popSize", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"fvals", "=", 
       RowBox[{"f", "/@", "pop"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"bestIdx", "=", 
       RowBox[{"First", "[", 
        RowBox[{"Ordering", "[", 
         RowBox[{"fvals", ",", "1"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"history", "=", 
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"pop", "[", 
           RowBox[{"[", "bestIdx", "]"}], "]"}], ",", "1", ",", 
          RowBox[{"fvals", "[", 
           RowBox[{"[", "bestIdx", "]"}], "]"}]}], "}"}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Do", "[", "\[IndentingNewLine]", 
       RowBox[{"(*", "elitism", "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"eliteIdx", "=", 
          RowBox[{"Ordering", "[", 
           RowBox[{"fvals", ",", "nElite"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"newPop", "=", 
          RowBox[{"pop", "[", 
           RowBox[{"[", "eliteIdx", "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{"crossover", "+", "mutation"}], "*)"}], 
         "\[IndentingNewLine]", 
         RowBox[{"While", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "newPop", "]"}], "<", "popSize"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"p1", "=", 
             RowBox[{"tournamentSelect", "[", 
              RowBox[{"pop", ",", "fvals", ",", "tournSize"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"p2", "=", 
             RowBox[{"tournamentSelect", "[", 
              RowBox[{"pop", ",", "fvals", ",", "tournSize"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"child", "=", 
             RowBox[{"orderCrossover", "[", 
              RowBox[{"p1", ",", "p2"}], "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"RandomReal", "[", "]"}], "<=", "Pm"}], ",", 
              RowBox[{"child", "=", 
               RowBox[{"neighbour", "[", "child", "]"}]}]}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"newPop", ",", "child"}], "]"}], ";"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"pop", "=", "newPop"}], ";", "\[IndentingNewLine]", 
         RowBox[{"fvals", "=", 
          RowBox[{"f", "/@", "pop"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"bestIdx", "=", 
          RowBox[{"First", "[", 
           RowBox[{"Ordering", "[", 
            RowBox[{"fvals", ",", "1"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"AppendTo", "[", 
          RowBox[{"history", ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"pop", "[", 
              RowBox[{"[", "bestIdx", "]"}], "]"}], ",", "gen", ",", 
             RowBox[{"fvals", "[", 
              RowBox[{"[", "bestIdx", "]"}], "]"}]}], "}"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"gen", ",", "2", ",", "ngen"}], "}"}]}], "]"}], ";", 
      "\[IndentingNewLine]", "history"}]}], "]"}]}], ";"}]}], "Input",
 CellLabel->"In[40]:=",ExpressionUUID->"3a57b41c-b509-5641-ac21-af1ba68ca9e2"],

