 Background->RGBColor[
  1, 1, 0.85],ExpressionUUID->"c930bdd1-2da6-4b16-97c4-14f08f48b6ec"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"neighbourB", "[", "x_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"xn", "=", "x"}], ",", "i", ",", "j"}], "}"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"i", ",", "j"}], "}"}], "=", 
       RowBox[{"RandomSample", "[", 
        RowBox[{
         RowBox[{"Range", "[", 
          RowBox[{"Length", "[", "x", "]"}], "]"}], ",", "2"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"xn", "[", 
          RowBox[{"[", "i", "]"}], "]"}], ",", 
         RowBox[{"xn", "[", 
          RowBox[{"[", "j", "]"}], "]"}]}], "}"}], "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"xn", "[", 
          RowBox[{"[", "j", "]"}], "]"}], ",", 
         RowBox[{"xn", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", "xn"}]}], "]"}]}], ";"}]], "Input",
 CellLabel->"In[24]:=",ExpressionUUID->"5e03313f-706b-224d-bd97-acbecbf77781"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3) Reverse sequence between two random points", "Subsubsection",
 CellChangeTimes->{{3.6641921713318*^9, 3.6641921840348*^9}, {
   3.6641929906428003`*^9, 3.6641929958227997`*^9}, {3.6641931161438*^9, 
