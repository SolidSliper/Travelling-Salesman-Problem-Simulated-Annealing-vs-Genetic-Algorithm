Cell[CellGroupData[{

Cell["11. Vizualizacia algoritmu cez Manipulate", "Section",ExpressionUUID->"03fc1faa-ca2e-f54e-ad4a-78ccda8ae317"],

Cell["\<\
Posuvanim k prechadzame jednotlive iteracie. Zobrazujeme stvorec, body, \
aktualnu cestu, hodnotu f(x) a teplotu T.
Pri velkom pocte iteracii moze byt Manipulate pomaly - preto historiu \
zriedime.\
\>", "Text",ExpressionUUID->"1cffa2b6-6c80-df42-81ac-da802e750b7b"],

Cell[CellGroupData[{

Cell["\<\
step = Max[1, Floor[Length[history]/500]];
historyShort = history[[1 ;; -1 ;; step]];

Manipulate[
  Show[square, plotPoints,
    pathGraphics[historyShort[[k, 1]]],
    PlotLabel -> Row[{
      \"iter \", k*step,
      \", T = \", NumberForm[historyShort[[k, 2]], {6, 4}],
      \", f(x) = \", NumberForm[historyShort[[k, 3]], {6, 4}]
    }]
  ],
  {k, 1, Length[historyShort], 1}
]\
\>", "Input",
 CellLabel->
  "In[300]:=",ExpressionUUID->"29a23e25-ccfa-2940-ade9-4bfe7b31e508"],

