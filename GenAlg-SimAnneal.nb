Cell[CellGroupData[{

Cell["3. Pociatocna nahodna permutacia", "Section",ExpressionUUID->"aa0b1cb9-0cd2-f94a-a904-6f0cca7412c6"],

Cell["\<\
x0 je nahodna permutacia 1..n. Funkcia pathGraphics nakresli cestu \
zodpovedajucu permutacii.\
\>", "Text",ExpressionUUID->"851e7050-8258-f042-b40d-c3d1b5e10c56"],

Cell[CellGroupData[{

Cell["\<\
x0 = RandomSample[Range[n]];
pathGraphics[x_] := Graphics[{
   Blue, Thick, Line[points[[x]]]
}];
Show[square, plotPoints, pathGraphics[x0]]\
\>", "Input",
