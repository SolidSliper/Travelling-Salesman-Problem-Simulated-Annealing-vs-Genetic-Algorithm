Cell[CellGroupData[{

Cell["4. Matica vzdialenosti L a ucelova funkcia f(x)", "Section",ExpressionUUID->"6bd7cf89-b1f2-9942-891b-5aa85963a471"],

Cell["\<\
Maticu L vypocitame raz na zaciatku. Dlzka cesty f(x) sa potom pocita len \
sucitanim spravnych prvkov L (rychlejsie nez opakovane volania \
EuclideanDistance).
Cesta je OTVORENA, takze sumacia ide od k=1 po n-1.\
\>", "Text",ExpressionUUID->"73652903-e4a9-e145-bb9a-e4ddd06ef26f"],

Cell[CellGroupData[{

Cell["\<\
L = Table[
\t
   EuclideanDistance[points[[i]], points[[j]]],
   {i, n}, {j, n}
];
f[x_] := Sum[L[[x[[k]], x[[k + 1]]]], {k, 1, Length[x] - 1}];

f[x0]\
\>", "Input",
 CellChangeTimes->{{3.987060524682804*^9, 3.987060625548725*^9}, {
  3.9870611646225853`*^9, 3.9870612040197945`*^9}, {3.9870614863330593`*^9, 
  3.98706151792931*^9}, {3.9871229251902447`*^9, 3.987122925674309*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"f2f54b74-cd5d-9f4f-9da3-5f6b3941c6c3"],

Cell[BoxData["10.434112148377245`"], "Output",
