Cell[CellGroupData[{

Cell["10. Geneticky algoritmus a simulovane zihanie", "Section",
 CellChangeTimes->{{3.9870630968307495`*^9, 3.987063109666172*^9}, {
  3.987123325256859*^9, 
  3.9871233312948437`*^9}},ExpressionUUID->"745e48a6-b84c-3641-b088-\
3db5e7391325"],

Cell["\<\
Hlavny algoritmus. Vracia historiu (cesta, teplota, hodnota f) pre kazdu \
iteraciu - potrebne pre vizualizaciu.\
\>", "Text",
 CellChangeTimes->{{3.9870508057396107`*^9, 
  3.987050806503559*^9}},ExpressionUUID->"0678cf0f-a1ad-0948-95d1-\
d9ea66265452"],

Cell["\<\
simulatedAnnealing[x0_, T0_, alpha_, Tmin_, kmax_, neighbour_] := Module[
  {x = x0, T = T0, xnew, df,
   history = {{x0, T0, f[x0]}}},
  While[T > Tmin,
    Do[
      xnew = neighbour[x];
      df = f[xnew] - f[x];
      If[P[df, T] >= RandomReal[], x = xnew];
      AppendTo[history, {x, T, f[x]}],
      {kmax}
    ];
    T = alpha*T;
  ];
  history
];\
\>", "Input",
 CellChangeTimes->{{3.9870618719030647`*^9, 3.9870618800629635`*^9}, {
   3.9870623434081097`*^9, 3.9870623455239487`*^9}, 3.987063121902302*^9},
 CellLabel->
  "In[288]:=",ExpressionUUID->"993b3a57-cd61-0548-b678-48eecfb1e64f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"orderCrossover", "[", 
    RowBox[{"p1_", ",", "p2_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"m", "=", 
        RowBox[{"Length", "[", "p1", "]"}]}], ",", "i", ",", "j", ",", "seg", 
       ",", "rest"}], "}"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"i", ",", "j"}], "}"}], "=", 
       RowBox[{"Sort", "[", 
        RowBox[{"RandomSample", "[", 
         RowBox[{
          RowBox[{"Range", "[", "m", "]"}], ",", "2"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"seg", "=", 
       RowBox[{"p1", "[", 
        RowBox[{"[", 
         RowBox[{"i", ";;", "j"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"rest", "=", 
       RowBox[{"Select", "[", 
        RowBox[{"p2", ",", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"MemberQ", "[", 
            RowBox[{"seg", ",", "#"}], "]"}]}], "&"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"rest", "[", 
         RowBox[{"[", 
          RowBox[{"1", ";;", 
           RowBox[{"i", "-", "1"}]}], "]"}], "]"}], ",", "seg", ",", 
        RowBox[{"rest", "[", 
         RowBox[{"[", 
          RowBox[{"i", ";;"}], "]"}], "]"}]}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"tournamentSelect", "[", 
    RowBox[{"population_", ",", "fvals_", ",", 
     RowBox[{"tournSize_", ":", "3"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "idx", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"idx", "=", 
       RowBox[{"RandomSample", "[", 
        RowBox[{
         RowBox[{"Range", "[", 
          RowBox[{"Length", "[", "population", "]"}], "]"}], ",", 
         "tournSize"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"population", "[", 
       RowBox[{"[", 
        RowBox[{"idx", "[", 
         RowBox[{"[", 
          RowBox[{"First", "[", 
           RowBox[{"Ordering", "[", 
            RowBox[{
             RowBox[{"fvals", "[", 
              RowBox[{"[", "idx", "]"}], "]"}], ",", "1"}], "]"}], "]"}], 
          "]"}], "]"}], "]"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"geneticAlgorithm", "[", 
    RowBox[{
    "popSize_", ",", "nCities_", ",", "nElite_", ",", "ngen_", ",", "Pm_", ",",
      "neighbour_", ",", 
     RowBox[{"tournSize_", ":", "4"}], ",", " ", "patience_"}], "]"}], ":=", 
   "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "pop", ",", "fvals", ",", "eliteIdx", ",", "newPop", ",", "p1", ",", 
       "p2", ",", "child", ",", "bestIdx", ",", "history", ",", 
       RowBox[{"noImprove", "=", "0"}], ",", "prevBest"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"pop", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"RandomSample", "[", 
          RowBox[{"Range", "[", "nCities", "]"}], "]"}], ",", 
         RowBox[{"{", "popSize", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"fvals", "=", 
       RowBox[{"f", "/@", "pop"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"bestIdx", "=", 
       RowBox[{"First", "[", 
        RowBox[{"Ordering", "[", 
         RowBox[{"fvals", ",", "1"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"history", "=", 
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"pop", "[", 
           RowBox[{"[", "bestIdx", "]"}], "]"}], ",", "1", ",", 
          RowBox[{"fvals", "[", 
           RowBox[{"[", "bestIdx", "]"}], "]"}], ",", 
          RowBox[{"Mean", "[", "fvals", "]"}]}], "}"}], "}"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"prevBest", "=", 
       RowBox[{"fvals", "[", 
        RowBox[{"[", "bestIdx", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"eliteIdx", "=", 
          RowBox[{"Ordering", "[", 
           RowBox[{"fvals", ",", "nElite"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"newPop", "=", 
          RowBox[{"pop", "[", 
           RowBox[{"[", "eliteIdx", "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"While", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "newPop", "]"}], "<", "popSize"}], ",", 
           RowBox[{
            RowBox[{"p1", "=", 
             RowBox[{"tournamentSelect", "[", 
              RowBox[{"pop", ",", "fvals", ",", "tournSize"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"p2", "=", 
             RowBox[{"tournamentSelect", "[", 
              RowBox[{"pop", ",", "fvals", ",", "tournSize"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"child", "=", 
             RowBox[{"orderCrossover", "[", 
              RowBox[{"p1", ",", "p2"}], "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"RandomReal", "[", "]"}], "<=", "Pm"}], ",", 
              RowBox[{"child", "=", 
               RowBox[{"neighbour", "[", "child", "]"}]}]}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"AppendTo", "[", 
             RowBox[{"newPop", ",", "child"}], "]"}], ";"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"pop", "=", "newPop"}], ";", "\[IndentingNewLine]", 
         RowBox[{"fvals", "=", 
          RowBox[{"f", "/@", "pop"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"bestIdx", "=", 
          RowBox[{"First", "[", 
           RowBox[{"Ordering", "[", 
            RowBox[{"fvals", ",", "1"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"AppendTo", "[", 
          RowBox[{"history", ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"pop", "[", 
              RowBox[{"[", "bestIdx", "]"}], "]"}], ",", "gen", ",", 
             RowBox[{"fvals", "[", 
              RowBox[{"[", "bestIdx", "]"}], "]"}], ",", 
             RowBox[{"Mean", "[", "fvals", "]"}]}], "}"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"fvals", "[", 
             RowBox[{"[", "bestIdx", "]"}], "]"}], "<", "prevBest"}], ",", 
           RowBox[{
            RowBox[{"prevBest", "=", 
             RowBox[{"fvals", "[", 
              RowBox[{"[", "bestIdx", "]"}], "]"}]}], ";", 
            RowBox[{"noImprove", "=", "0"}]}], ",", 
           RowBox[{"noImprove", "++"}]}], "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"noImprove", ">=", "patience"}], ",", 
           RowBox[{"Break", "[", "]"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"gen", ",", "2", ",", "ngen"}], "}"}]}], "]"}], ";", 
      "\[IndentingNewLine]", "history"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9870623544418087`*^9, 3.987062455332058*^9}, {
