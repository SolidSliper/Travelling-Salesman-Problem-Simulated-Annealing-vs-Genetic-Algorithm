Cell["\<\
Spustenie SA. Operator (c) - reverse - dava najlepsie vysledky pre TSP \
(zodpoveda heuristike 2-opt).\
\>", "Text",ExpressionUUID->"0deb5cef-1455-2e43-99c8-5d9baa7cda34"],

Cell[CellGroupData[{

Cell["\<\
T0 = T0auto;
alpha = 0.95;
Tmin = 0.001;
kmax = 200;
history = simulatedAnnealing[x0, T0, alpha, Tmin, kmax, neighbourC];
Print[\"# iter = \", Length[history]];

xSA = history[[-1, 1]];
Print[\"f(xSA) = \", f[xSA]];
Show[square, plotPoints, pathGraphics[xSA],
 PlotLabel -> \"SA, f = \" <> ToString[f[xSA]]]\
\>", "Input",
 CellChangeTimes->{{3.987655024348608*^9, 3.98765506645039*^9}},
 CellLabel->
  "In[289]:=",ExpressionUUID->"ff701ec2-971f-9a44-8afe-48e3c1b1db26"],

