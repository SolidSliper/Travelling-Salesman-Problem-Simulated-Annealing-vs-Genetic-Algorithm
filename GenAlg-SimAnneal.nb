Cell[CellGroupData[{

Cell["2. n nahodnych bodov v stvorci", "Section",ExpressionUUID->"7c4d0843-e1d3-5942-b50a-4b22e9b65caa"],

Cell[CellGroupData[{

Cell["\<\
SeedRandom[15];
n = 20;
points = RandomReal[{0, 1}, {n, 2}];

plotPoints = Graphics[{
   PointSize[0.02], Red, Point /@ points,
   Black,
   MapIndexed[
    Text[Style[#2[[1]], 10, Bold], #1 + {0.02, 0.02}] &,
    points
   ]
}];
Show[square, plotPoints]\
\>", "Input",
